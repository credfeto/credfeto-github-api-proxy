# Port the proxy listens on (default: 3000)
PORT=3000

# The fake token you issue to agents.
# Generate something long and random, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PROXY_TOKEN=your-fake-agent-token-here

# Your real GitHub PAT (classic or fine-grained).
# Needs: repo, read:org, workflow scopes (classic)
# OR:   Issues R/W, Pull Requests R/W, Actions R, Workflows R (fine-grained)
GITHUB_PAT=ghp_your_real_github_pat_here
