# Port the proxy listens on (default: 3000)
PORT=3000

# Path to a JSON file containing an array of {proxyToken, githubPat} pairs.
# Copy credentials.example.json to credentials.json, fill it in, then set:
#
# CREDENTIALS_FILE=./credentials.json
#
# The file is gitignored. Each entry maps one fake proxy token to one real PAT,
# so different agents can use different GitHub accounts or permission scopes.
# Generate a long random proxy token, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

CREDENTIALS_FILE=./credentials.json
