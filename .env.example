# Port the proxy listens on (default: 3000)
PORT=3000

# ── Option A: credentials file (recommended for multiple agents) ────────────
#
# Path to a JSON file containing an array of {proxyToken, githubPat} pairs.
# Copy credentials.example.json to credentials.json, fill it in, then set:
#
# CREDENTIALS_FILE=./credentials.json
#
# The file is gitignored. Each entry maps one fake proxy token to one real PAT,
# so different agents can use different GitHub accounts or permission scopes.

# ── Option B: single pair via environment variables (simple / backward-compat)
#
# If CREDENTIALS_FILE is not set, the proxy falls back to these two variables.
# Generate a long random proxy token, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

PROXY_TOKEN=your-fake-agent-token-here

# Your real GitHub PAT (classic or fine-grained).
# Needs: repo, read:org, workflow scopes (classic)
# OR:   Issues R/W, Pull Requests R/W, Actions R, Workflows R (fine-grained)
GITHUB_PAT=ghp_your_real_github_pat_here
